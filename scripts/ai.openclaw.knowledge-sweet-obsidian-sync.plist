<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>ai.openclaw.knowledge-sweet-obsidian-sync</string>

  <key>ProgramArguments</key>
  <array>
    <string>&lt;YOUR_OPENCLAW_HOME&gt;/workspace/knowledge-sweet/sync-to-obsidian.sh</string>
  </array>

  <key>RunAtLoad</key>
  <true/>

  <key>StartInterval</key>
  <integer>300</integer>

  <key>StandardOutPath</key>
  <string>&lt;YOUR_OPENCLAW_HOME&gt;/logs/knowledge-sweet-obsidian-sync.log</string>

  <key>StandardErrorPath</key>
  <string>&lt;YOUR_OPENCLAW_HOME&gt;/logs/knowledge-sweet-obsidian-sync.err.log</string>
</dict>
</plist>
